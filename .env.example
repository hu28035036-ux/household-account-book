# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=receipts

# OpenAI (1순위) — sk-... 형식, Vercel env 에 secret 으로 등록
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama (선택, fallback) — 둘 다 비워두면 AI 기능 비활성화.
# OPENAI_API_KEY 가 있으면 Ollama 는 OpenAI 장애 시에만 호출됨.
OLLAMA_API_BASE_URL=
OLLAMA_MODEL=gemma4:e4b
OLLAMA_API_TOKEN=

# OCR
OCR_LANGUAGE=kor+eng

# App
APP_ENV=development
RAW_TEXT_TTL_DAYS=7
NEXT_PUBLIC_RAW_TEXT_TTL_DAYS=7
NEXT_PUBLIC_OCR_LANGUAGE=kor+eng

# Cron
CRON_TOKEN=

# Admin (지인 배포 — 콤마 구분 이메일 목록)
ADMIN_EMAILS=
